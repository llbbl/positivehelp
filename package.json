{
	"name": "positivehelp",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@11.1.3",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"vercel-build": "pnpm db:migrate && next build",
		"start": "pnpm db:migrate && next start",
		"lint": "pnpm exec biome lint .",
		"db:generate": "drizzle-kit generate --config drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
		"db:reset": "drizzle-kit reset --config drizzle.config.ts",
		"test": "jest",
		"test:watch": "jest --watch",
		"check-file": "node scripts/check-file.js",
		"bun-tsc": "bun scripts/check-file.js",
		"node-tsc": "node scripts/check-file.js",
		"delete-message": "tsx scripts/delete-message.ts"
	},
	"dependencies": {
		"@babel/helpers": "^7.29.7",
		"@clerk/nextjs": "^7.5.7",
		"@libsql/client": "^0.17.4",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-toast": "^1.2.17",
		"@tanstack/react-table": "^8.21.3",
		"better-sqlite3": "^12.11.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"lucide-react": "^1.21.0",
		"next": "16.2.9",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss-animate": "^1.0.7",
		"winston": "^3.19.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@jest/globals": "^30.4.1",
		"@next/env": "^16.2.9",
		"@tailwindcss/postcss": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.10",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "30.4.1",
		"postcss": "^8.5.15",
		"tailwindcss": "^4.3.1",
		"ts-jest": "^29.4.11",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "jsdom",
		"setupFilesAfterEnv": [
			"<rootDir>/jest.setup.ts"
		],
		"moduleNameMapper": {
			"^@/(.*)$": "<rootDir>/$1"
		},
		"transform": {
			"^.+\\.(ts|tsx)$": [
				"ts-jest",
				{
					"tsconfig": {
						"jsx": "react-jsx"
					}
				}
			]
		}
	}
}
